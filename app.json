{
  "expo": {
    "name": "ClinicApp",
    "slug": "clinic-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clinicapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#070e1a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clinicapp.mobile",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.clinicapp.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#070e1a"
      },
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to upload profile pictures and analysis results."
        }
      ],
      "expo-font",
      "./plugins/withNonModularHeaders",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6cce270b-30d7-4df9-b0ce-63241d7ee61b"
      },
      "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_51TP7Zp5uQOYiQRCq1X47x56En44VZB6kYk6kZoi6uX4XOhNKlIPk9wqFWJofC8ub4rPim2hoUzavvu4r4BwqYdMg00PW9GN9GL"
    }
  }
}
